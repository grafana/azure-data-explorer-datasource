{
  "name": "grafana-azure-data-explorer-datasource",
  "version": "7.2.7",
  "description": "Grafana data source for Azure Data Explorer",
  "scripts": {
    "build": "webpack -c ./.config/webpack/webpack.config.ts --env production",
    "dev": "webpack -w -c ./.config/webpack/webpack.config.ts --env development",
    "e2e:playwright": "npx --package @playwright/test playwright test",
    "e2e:playwright:ui": "npx --package @playwright/test playwright test --ui",
    "e2e:playwright:report": "npx --package @playwright/test playwright show-report",
    "i18n-extract": "i18next --config src/locales/i18next-parser.config.cjs",
    "lint": "eslint --cache .",
    "lint:fix": "npm run lint -- --fix && prettier --write --list-different .",
    "server": "docker compose up --build",
    "sign": "npx --yes @grafana/sign-plugin@latest",
    "test": "jest --watch --onlyChanged",
    "test:ci": "jest --passWithNoTests --maxWorkers 4",
    "test:coverage": "jest --coverage",
    "test:coverage:changes": "jest --coverage --changedSince=origin/main",
    "typecheck": "tsc --noEmit",
    "generate-release-notes": "PREV_TAG=$(git tag | tail -n 1) && gh api --method POST /repos/grafana/azure-data-explorer-datasource/releases/generate-notes -f tag_name=v${npm_package_version} -f target_commitish=main -f previous_tag_name=${PREV_TAG} | jq -r .body",
    "spellcheck": "cspell -c cspell.config.json \"**/*.{ts,tsx,js,go,md,mdx,yml,yaml,json,scss,css}\"",
    "e2e": "playwright test"
  },
  "engines": {
    "node": ">=24.5.0",
    "npm": ">=11"
  },
  "author": "Grafana Labs",
  "license": "Apache",
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@babel/core": "7.29.6",
    "@eslint/compat": "2.1.0",
    "@grafana/eslint-config": "9.0.0",
    "@grafana/plugin-e2e": "3.9.2",
    "@grafana/plugin-meta-extractor": "0.13.0",
    "@grafana/tsconfig": "2.2.0",
    "@playwright/test": "1.61.1",
    "@stylistic/eslint-plugin-ts": "4.4.1",
    "@swc/core": "1.15.43",
    "@swc/helpers": "0.5.23",
    "@swc/jest": "0.2.39",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/chance": "1.1.8",
    "@types/debounce-promise": "3.1.9",
    "@types/glob": "8.1.0",
    "@types/jest": "29.5.14",
    "@types/lodash": "4.17.24",
    "@types/node": "22.20.1",
    "@types/prismjs": "1.26.6",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/react-router-dom": "5.3.3",
    "@types/uuid": "10.0.0",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "chance": "1.1.13",
    "copy-webpack-plugin": "14.0.0",
    "cspell": "9.8.0",
    "css-loader": "7.1.4",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "eslint-plugin-prettier": "5.5.6",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-webpack-plugin": "5.0.3",
    "fork-ts-checker-webpack-plugin": "9.1.0",
    "glob": "13.0.6",
    "i18next-parser": "9.4.0",
    "identity-obj-proxy": "3.0.0",
    "imports-loader": "5.0.0",
    "jest": "29.7.0",
    "jest-environment-jsdom": "29.7.0",
    "monaco-editor": "0.55.1",
    "node-notifier": "10.0.1",
    "prettier": "3.9.5",
    "prismjs": "1.30.0",
    "react-select-event": "5.5.1",
    "replace-in-file-webpack-plugin": "1.0.6",
    "sass": "1.101.0",
    "sass-loader": "16.0.8",
    "semver": "7.8.5",
    "style-loader": "4.0.0",
    "swc-loader": "0.2.7",
    "terser-webpack-plugin": "5.6.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.9.3",
    "uuid": "14.0.1",
    "webpack": "5.108.4",
    "webpack-cli": "7.2.1",
    "webpack-livereload-plugin": "3.0.2",
    "webpack-subresource-integrity": "5.1.0",
    "webpack-virtual-modules": "0.6.2"
  },
  "dependencies": {
    "@emotion/css": "11.13.5",
    "@grafana/azure-sdk": "0.1.0",
    "@grafana/data": "12.4.5",
    "@grafana/i18n": "12.4.5",
    "@grafana/llm": "1.0.9",
    "@grafana/plugin-ui": "0.16.1",
    "@grafana/runtime": "12.4.5",
    "@grafana/schema": "12.4.5",
    "@grafana/ui": "12.4.5",
    "debounce-promise": "3.1.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-use": "17.6.1",
    "tslib": "2.8.1"
  },
  "overrides": {
    "immutable": "5.1.9",
    "@react-awesome-query-builder/core": {
      "immutable": "4.3.9"
    },
    "lodash": "4.18.1",
    "protobufjs": "7.6.3",
    "flatted": "3.4.2",
    "form-data": "4.0.6"
  },
  "packageManager": "npm@11.18.0"
}
